# LILAK Elog — example environment file.
# Copy to .env.local and edit if the assigned ports collide on this machine.

# Backend FastAPI / uvicorn
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8010

# Frontend Vite dev server (only used during `npm run dev`; the production
# build is served by the backend itself)
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5010

# Where the frontend talks to the backend during dev. Used by vite.config.js
# proxy and by `VITE_API_URL` if/when the frontend needs an absolute URL.
VITE_API_URL=http://localhost:8010

# Experiment name (per-experiment DB + uploads folder)
ELOG_EXPERIMENT=default
