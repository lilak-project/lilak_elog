# ──────────────────────────────────────────────────────────────────────────
#  lilak_elog_v2 (frontend) — environment template
#
#  WHAT THIS IS
#    A list of settings this app can read at startup. Lines are KEY=value.
#    Lines starting with # are comments (ignored).
#
#  HOW TO USE (per machine, once)
#    1.  cp .env.example .env.local
#    2.  edit .env.local with the values for THIS machine
#    3.  npm run dev      (Vite reads .env.local automatically)
#
#  IMPORTANT
#    - .env.local is git-ignored on purpose — it is private to this machine.
#    - Commit ONLY this .env.example (with placeholder values), never .env.local.
#    - These values are NOT secrets here (just ports/addresses). Real secrets
#      belong in a backend .env, never in a frontend bundle.
#    - If you delete a line, the app falls back to the default shown below.
# ──────────────────────────────────────────────────────────────────────────

# Port the dev server listens on (the page you open in the browser).
# Default: 5130
PORT=5130

# Where the default elog backend lives (used when no experiment is selected).
# The Vite dev server forwards /api/* here.
# Default: http://localhost:8011
ELOG_BACKEND=http://localhost:8011

# Where the launcher lives (the project/experiment list + per-experiment proxy).
# The Vite dev server forwards /launcher/* here.
# Default: http://localhost:8010
ELOG_LAUNCHER=http://localhost:8010
