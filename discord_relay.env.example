# Copy this to "discord_relay.env" (without the .example) and fill in your values.
# Do NOT commit discord_relay.env — it contains secrets.

# Get this from lilak: Settings → 커뮤니티 브리지 → Discord 카드 → Incoming webhook → copy
LILAK_INCOMING_URL=(여기에_lilak_incoming_URL_붙여넣기)

# Get this from https://discord.com/developers → your app → Bot → Reset Token
DISCORD_BOT_TOKEN=(여기에_새_봇_토큰_붙여넣기)

# (Optional) Limit relay to specific channels. Comma-separated channel IDs.
# Empty = relay all channels the bot can see.
# To copy a channel ID: enable Discord Settings → Advanced → Developer Mode,
# then right-click the channel → "Copy Channel ID".
DISCORD_CHANNEL_IDS=
